# ─────────────────────────────────────────────────────────────────────────────
# LMS Platform — Environment Variables
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=lms_db
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=lms_password

# ─── JWT ─────────────────────────────────────────────────────────────────────
# MUST change in production! Use a random 256-bit base64 string.
# Generate: openssl rand -base64 32
APP_JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_SECRET_256BIT

# Access token TTL (milliseconds). Default: 15 minutes
APP_JWT_EXPIRATION_MS=900000

# Refresh token TTL (days). Default: 30 days
APP_REFRESH_TOKEN_EXPIRATION_DAYS=30

# ─── File Storage ─────────────────────────────────────────────────────────────
# Public base URL for uploaded files as seen by clients.
# With nginx proxy on port 80:
APP_STORAGE_BASE_URL=http://localhost/uploads

# ─── Frontend / Admin (Vite build-time env vars) ─────────────────────────────
# API base URL injected into the Vite build.
# With nginx proxy: /api  (nginx strips the /api prefix before forwarding)
# Without nginx:    http://localhost:8080
VITE_API_BASE_URL=/api
